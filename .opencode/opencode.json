{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "rocq-mcp": {
            "enabled": true,
            "type": "local",
            "command": [
                "/home/valentin/epfl/masterProject/rocq-mcp/.venv/bin/rocq-mcp"
            ],
            "environment": {
                "ROCQ_WORKSPACE": "/home/valentin/epfl/masterProject/warblre",
                "ROCQPATH": "_build/default/mechanization",
                "ROCQ_COQC_BINARY": "coqc",
                "ROCQ_PET_TIMEOUT": "30",
                "ROCQ_COQC_TIMEOUT": "60",
                "ROCQ_VERIFY_TIMEOUT": "120"
            }
        },
        "warblre-context": {
            "enabled": true,
            "type": "local",
            "command": [
                "node",
                "/home/valentin/epfl/masterProject/warblre/.opencode/mcp/warblre-server.js"
            ],
            "environment": {}
        }
    },
    "agent": {
        "fix_test262_batch": {
            "description": "{file:./agents/fix_test262_batch/description.md}",
            "prompt": "{file:./agents/fix_test262_batch/prompt.md}",
            "tools": {
                "task": true
            }
        },
        "fix_test262_file": {
            "description": "{file:./agents/fix_test262_file/description.md}",
            "prompt": "{file:./agents/fix_test262_file/prompt.md}"
        },
        "annotate_rocq": {
